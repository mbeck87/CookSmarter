<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="834.0" prefWidth="1204.0" stylesheets="@../styles/app.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <AnchorPane prefHeight="90.0" prefWidth="1204.0" styleClass="header" BorderPane.alignment="CENTER">
         <children>
            <StackPane prefHeight="46.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <Label styleClass="header-title" text="Rezept erstellen" />
               </children>
            </StackPane>
            <TextField fx:id="fSearch" onKeyReleased="#SearchKeyReleased" prefHeight="30.0" promptText="Zutaten suchen …" styleClass="search-field" AnchorPane.bottomAnchor="12.0" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" />
         </children>
      </AnchorPane>
   </top>
   <center>
      <ScrollPane fx:id="scrollPane" styleClass="content-scroll" BorderPane.alignment="CENTER">
         <content>
            <FlowPane fx:id="flowPane" styleClass="content-flow" prefHeight="200.0" prefWidth="200.0" />
         </content>
      </ScrollPane>
   </center>
   <right>
      <ScrollPane fx:id="recipeScroll" fitToWidth="true" hbarPolicy="NEVER" prefWidth="300.0" styleClass="detail-panel-scroll" BorderPane.alignment="CENTER">
         <content>
            <VBox fx:id="recipeBox" spacing="10.0" styleClass="detail-panel">
               <padding>
                  <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
               </padding>
               <children>
                  <HBox alignment="CENTER" spacing="12.0">
                     <children>
                        <StackPane alignment="CENTER" prefHeight="115.0" prefWidth="115.0" styleClass="image-container">
                           <children>
                              <ImageView fx:id="imageView" fitHeight="103.0" fitWidth="103.0" pickOnBounds="true" preserveRatio="true" />
                           </children>
                        </StackPane>
                        <VBox alignment="CENTER" spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#pictureAction" styleClass="btn-secondary" text="Bild wählen" />
                              <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#saveAction" styleClass="btn-primary" text="Speichern" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <GridPane hgap="8.0" vgap="4.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="80.0" />
                        <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="70.0" />
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="24.0" prefHeight="24.0" vgrow="SOMETIMES" />
                     </rowConstraints>
                     <children>
                        <Label styleClass="nutrition-label" text="Energie (kJ)" />
                        <Label fx:id="lEnergy" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" />
                        <Label styleClass="nutrition-label" text="Kalorien (kcal)" GridPane.rowIndex="1" />
                        <Label fx:id="lKcal" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label styleClass="nutrition-label" text="Kohlenhydrate (g)" GridPane.rowIndex="2" />
                        <Label fx:id="lCarbohydrates" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label styleClass="nutrition-label" text="Zucker (g)" GridPane.rowIndex="3" />
                        <Label fx:id="lSugar" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                        <Label styleClass="nutrition-label" text="Fett (g)" GridPane.rowIndex="4" />
                        <Label fx:id="lFat" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        <Label styleClass="nutrition-label" text="Salz (g)" GridPane.rowIndex="5" />
                        <Label fx:id="lSalt" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                        <Label styleClass="nutrition-label" text="Proteine (g)" GridPane.rowIndex="6" />
                        <Label fx:id="lProtein" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                        <Label styleClass="nutrition-label" text="Ballaststoffe (g)" GridPane.rowIndex="7" />
                        <Label fx:id="lFiber" styleClass="nutrition-value" text="0" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                     </children>
                  </GridPane>
                  <TextArea fx:id="textArea" prefHeight="200.0" prefWidth="307.0" styleClass="notes-area" wrapText="true" />
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </right>
</BorderPane>
