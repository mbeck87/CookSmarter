                        <Label styleClass="sidebar-brand-label" text="CookSmarter" />
                        <Label styleClass="sidebar-brand-sub" text="Küche &amp; Ernährung" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <Region prefHeight="4.0" />

            <!-- Section: Zutaten -->
            <Label styleClass="sidebar-section" text="ZUTATEN" />

            <HBox fx:id="menuIngredient" alignment="CENTER_LEFT" onMouseClicked="#menuCreateIngredientClicked" onMouseEntered="#menuEntered" onMouseExited="#menuExited" spacing="10.0" styleClass="sidebar-item">
