            <HBox fx:id="menuCreateRecipe" alignment="CENTER_LEFT" onMouseClicked="#menuCreateRecipeClicked" onMouseEntered="#menuEntered" onMouseExited="#menuExited" spacing="10.0" styleClass="sidebar-item">
