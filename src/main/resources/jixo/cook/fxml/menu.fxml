            <HBox fx:id="menuImported" alignment="CENTER_LEFT" onMouseClicked="#menuImportedIngredientClicked" onMouseEntered="#menuEntered" onMouseExited="#menuExited" spacing="10.0" styleClass="sidebar-item">
